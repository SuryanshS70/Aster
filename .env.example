# Public browser configuration (safe to expose; currently unused)
VITE_API_BASE_URL=

# Application server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
REQUEST_BODY_LIMIT_BYTES=1048576
SHUTDOWN_TIMEOUT_MS=10000

# PostgreSQL (replace placeholders for local use)
POSTGRES_USER=aster
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_DB=aster
DATABASE_URL=postgresql://aster:replace-with-a-local-password@localhost:5432/aster

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=aster

# Authentication (server-only; replace all security placeholders)
SESSION_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:8080
TRUSTED_ORIGINS=http://localhost:8080,http://localhost:3000

# Development email (Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=Aster <no-reply@aster.local>

# Gemini generation (server-only; set locally)
GEMINI_API_KEY=
GEMINI_MODEL=
